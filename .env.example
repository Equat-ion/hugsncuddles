# --- LLM ---
LLM_BASE_URL=https://example-hackclub-ai-endpoint
LLM_API_KEY=sk-your-key
LLM_MODEL=qwen/qwen3-coder
LLM_MAX_TOKENS=2048

# --- Database / Queue ---
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/graft

# --- GitHub App (for PR creation + branch pushing) ---
# Create at: GitHub → Settings → Developer settings → GitHub Apps
# Permissions needed: Contents (R/W), Pull requests (R/W)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_INSTALLATION_ID=12345678

# --- GitHub PAT (for reading public changelogs/releases, avoids 60 req/hr rate limit) ---
# Generate at: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
# Scopes needed: public_repo (read-only is fine for public repos)
GITHUB_TOKEN=ghp_your_personal_access_token

# --- e2b (cloud sandbox for running pytest safely) ---
# Get your API key at: https://e2b.dev/dashboard → API Keys
# Free tier: 100 sandbox-hours/month
E2B_API_KEY=e2b_your_api_key_here

# --- Feature Flags ---
SANDBOX_BACKEND=e2b
ENABLE_TRAINING=true
ENABLE_REGISTRY_TRIGGERS=true
ENABLE_REGRESSION_CHECKS=true
ENABLE_STREAMING=true
